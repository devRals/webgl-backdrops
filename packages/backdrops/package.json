{
    "name": "@devrals/backdrops",
    "version": "0.2.5",
    "type": "module",
    "packageManager": "pnpm@10.29.2",
    "license": "MIT",
    "description": "A couple sets of backgrounds based of @devrals/webgl-engine and three.js",
    "files": [
        "dist"
    ],
    "author": {
        "name": "devRals",
        "url": "https://devrals.github.io/"
    },
    "scripts": {
        "build": "vite build"
    },
    "keywords": [
        "backdrops",
        "backgrounds"
    ],
    "dependencies": {
        "@devrals/math": "^0.2.3",
        "@devrals/webgl-engine": "^0.1.4"
    },
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "default": "./dist/index.js"
        },
        "./northern-lights": {
            "types": "./dist/src/northern_lights/index.d.ts",
            "default": "./dist/northern_lights.js"
        },
        "./dream-stars": {
            "types": "./dist/src/dream-stars/index.d.ts",
            "default": "./dist/dream-stars.js"
        },
        "./among-us": {
            "types": "./dist/src/AMOGUS/index.d.ts",
            "default": "./dist/among-us.js"
        },
        "./black_hole": {
            "types": "./dist/src/black_hole.d.ts",
            "default": "./dist/black-hole.js"
        }
    }
}
